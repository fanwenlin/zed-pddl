{
  "name": "zed-pddl-lsp",
  "version": "0.1.0",
  "private": true,
  "description": "PDDL language server for the Zed PDDL extension",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run bundle",
    "bundle": "esbuild dist/server.js --bundle --platform=node --format=cjs --outfile=dist/pddl-lsp.cjs",
    "test": "npm run build && node --test dist/test/**/*.test.js"
  },
  "dependencies": {
    "pddl-workspace": "^11.3.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.11",
    "typescript": "^5.8.3"
  }
}
